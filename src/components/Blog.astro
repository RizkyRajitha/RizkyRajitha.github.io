---
import BlogPostCard from "../components/unit/BlogPostCard.astro";
import BlogFooter from "./unit/BlogFooter.astro";
import Navigation from "./unit/Navigation.astro";

const { posts } = Astro.props;
---

<Navigation currentPage="blog" />

<main>
    <div class="animate-fade-in">
        <header class="mb-16 space-y-4">
            <h1
                class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-100"
            >
                Blog
            </h1>
            <p class="text-zinc-400 text-lg max-w-xl leading-relaxed">
                Thoughts on software engineering, design, and building things
                for the web.
            </p>
        </header>

        <div class="flex flex-col gap-12">
            {posts.map((post) => <BlogPostCard post={post} />)}
        </div>
    </div>
</main>

<BlogFooter />