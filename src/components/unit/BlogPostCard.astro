---
import { Icon } from "astro-icon/components";
import { DateTime } from "luxon";

const { post } = Astro.props;

const relative = DateTime.fromISO(
    post.data.publishedDate.toISOString(),
).toRelative();

const formattedDate = DateTime.fromISO(
    post.data.publishedDate.toISOString(),
).toFormat("LLL dd, yyyy");
---

<article class="group cursor-pointer flex flex-col items-start">
    <a href={`/post/${post.id}`} class="block w-full">
        <div
            class="flex items-center gap-3 text-sm text-zinc-500 mb-3 font-mono"
        >
            <Icon name="fa7-solid:clock" class="w-4 h-4" />
            <span
                class="group/tooltip relative cursor-help border-b border-dotted border-zinc-600 hover:border-zinc-400 transition-colors"
            >
                {relative}
                <span
                    class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover/tooltip:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap rounded bg-zinc-800 px-2 py-1 text-xs text-zinc-200 shadow-lg z-10 before:content-[''] before:absolute before:top-full before:left-1/2 before:-translate-x-1/2 before:border-[5px] before:border-transparent before:border-t-zinc-800"
                >
                    {formattedDate}
                </span>
            </span>
        </div>

        <h2
            class="text-lg md:text-xl font-medium text-zinc-200 group-hover:text-white transition-colors mb-3"
        >
            {post.data.title}
        </h2>

        <p
            class="text-zinc-400 leading-relaxed max-w-2xl group-hover:text-zinc-300 transition-colors"
        >
            {post.data.description}
        </p>

        <div
            class="mt-4 flex items-center text-sm font-medium text-zinc-500 group-hover:text-zinc-300 transition-colors"
        >
            Read article
            <span
                class="ml-1 transition-transform duration-300 group-hover:translate-x-1"
                >→</span
            >
        </div>
    </a>
</article>
