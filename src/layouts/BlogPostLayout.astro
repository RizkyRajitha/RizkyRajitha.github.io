---
import { Icon } from "astro-icon/components";
import BlogFooter from "../components/unit/BlogFooter.astro";
import { DateTime } from "luxon";

const baseUrl = "https://rizkyrajitha.com";

const { post } = Astro.props;

const relative = DateTime.fromISO(
    post.data.publishedDate.toISOString(),
).toRelative();
console.log(relative);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={post.data.description} />
        <meta name="og:description" content={post.data.description} />

        <meta name="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={post.data.title} />
        <meta name="twitter:description" content={post.data.description} />

        <meta name="twitter:description" content={post.data.description} />
        <meta
            name="og:image"
            content={`${baseUrl}/ogimage/${post.data.ogImage}`}
        />

        <meta name="og:locale" content="si_LK" />
        <meta name="og:site_name" content="Rajitha's Blog" />

        <meta
            name="twitter:site"
            content={`https://twitter.com/rizkyrajitha`}
        />
        <meta
            name="keywords"
            content="software, coding, development, engineering"
        />

        <meta name="og:title" content={post.data.title} />
        <title>{post.data.title}</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
    </head>

    <body>
        <div class="blogpostcontainer">
            <nav class="navbar navbar-dark bg-primary navbar-expand-lg">
                <div class="container">
                    <a class="navbarhome navbar-brand" href="/">
                        Rizky's Blog
                    </a>
                    <div class="justify-content-end" id="basic-navbar-nav">
                        <span class="navbar-text navbarhome">
                            <div class="d-flex align-items-center">
                                <a
                                    href="/blog"
                                    class="d-flex align-items-center gap-1"
                                >
                                    <Icon
                                        name="fa7-regular:home"
                                        height={20}
                                        width={20}
                                    />
                                    Home
                                </a>
                            </div>
                        </span>
                    </div>
                </div>
            </nav>
            <div class="container blogpostcontent">
                <div class="row">
                    <div class="col-lg-12 col-xl-12 col-xxl-12">
                        <h1 class="mt-4">{post.data.title}</h1>

                        <hr />
                        <p>
                            Posted {relative}
                        </p>

                        <hr />

                        <div style={{ fontSize: "1.28em" }}>
                            <slot />
                        </div>
                    </div>
                </div>
            </div>
            <BlogFooter />
        </div>
    </body>
</html>

<script>
    document.querySelectorAll(".markdown-image-wrapper img").forEach((img) => {
        const reveal = () => {
            const wrapper = img.closest(".markdown-image-wrapper");
            const placeholder = wrapper?.querySelector(".blur-placeholder");

            img.style.opacity = "1";
            if (placeholder) placeholder.style.opacity = "0";
        };

        // already cached (navigating back, fast load)
        img.complete ? reveal() : img.addEventListener("load", reveal);
    });
</script>

<style>
    :global(.markdown-image-wrapper) {
        margin: 1.5rem auto;
        border-radius: 10px;
    }

    :global(.markdown-image-wrapper img) {
        border-radius: 10px;
    }

    :global(.blur-placeholder) {
        border-radius: 10px;
        filter: blur(8px); /* extra softness on the placeholder itself */
        transform: scale(1.05); /* hide the blur edge artifact */
    }

    :global(pre.astro-code) {
        padding: 0.6rem;
        border-radius: 6px;
    }

    :global(a) {
        text-decoration: none;
    }

    :global(:not(pre) > code) {
        color: #ffcc00;
        background-color: #1e1e1e;
        padding: 2px 6px;
        border-radius: 6px;
    }

    :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 10px;
    }

    :global(div.markdown-image-bg-placeholder) {
        border-radius: 6px;
        margin: 4%;
    }

    .blogpostcontainer {
        color: #ffffff;
        background-color: #243447;
        font-family: "Montserrat", sans-serif;

        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .blogpostcontent {
        flex: 1;
    }
</style>
