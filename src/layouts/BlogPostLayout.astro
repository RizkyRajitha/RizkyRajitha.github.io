---
import { Icon } from "astro-icon/components";
import BlogFooter from "../components/unit/BlogFooter.astro";
import Navigation from "../components/unit/Navigation.astro";
import { DateTime } from "luxon";
import "@fontsource/space-mono";

const origin = Astro.url.origin;

const { post } = Astro.props;

const relative = DateTime.fromISO(
    post.data.publishedDate.toISOString(),
).toRelative();

const formattedDate = DateTime.fromISO(
    post.data.publishedDate.toISOString(),
).toFormat("LLL dd, yyyy");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={post.data.description} />
        <meta name="og:description" content={post.data.description} />

        <meta name="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={post.data.title} />
        <meta name="twitter:description" content={post.data.description} />

        <meta
            name="og:image"
            content={`${origin}/ogimg/${post.data.ogImage}`}
        />

        <meta property="og:locale" content="en_US" />
        <meta name="og:site_name" content="Rajitha's Blog" />

        <meta
            name="twitter:site"
            content={`https://twitter.com/rizkyrajitha`}
        />
        <meta
            name="keywords"
            content="software, coding, development, engineering"
        />

        <meta name="og:title" content={post.data.title} />
        <title>{post.data.title}</title>
        <script
            async
            defer
            data-website-id="02687704-8c50-4293-87a1-adfc7daf88b7"
            src="https://umami-five.vercel.app/script.js"></script>
    </head>

    <body
        class="min-h-screen bg-[#18181B] text-zinc-300 font-sans selection:bg-zinc-700 selection:text-white overflow-x-hidden"
    >
        <div class="max-w-3xl mx-auto px-6 md:px-8">
            <Navigation />

            <div>
                <a
                    href="/blog"
                    class="group inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-zinc-200 transition-colors mb-12 font-medium"
                >
                    <span
                        class="transition-transform group-hover:-translate-x-1"
                        >←</span
                    >
                    Back to blog
                </a>

                <article>
                    <header class="mb-14">
                        <h1
                            class="text-3xl md:text-5xl font-semibold tracking-tight text-zinc-100 mb-6 leading-[1.15]"
                        >
                            {post.data.title}
                        </h1>

                        <div
                            class="flex items-center gap-6 text-sm text-zinc-500 font-mono"
                        >
                            <div class="flex items-center gap-2">
                                <Icon
                                    name="fa7-regular:clock"
                                    class="w-4 h-4"
                                />
                                <span
                                    class="group/tooltip relative cursor-help border-b border-dotted border-zinc-600 hover:border-zinc-400 transition-colors"
                                >
                                    Posted {relative}
                                    <span
                                        class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover/tooltip:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap rounded bg-zinc-800 px-2 py-1 text-xs text-zinc-200 shadow-lg z-10 before:content-[''] before:absolute before:top-full before:left-1/2 before:-translate-x-1/2 before:border-[5px] before:border-transparent before:border-t-zinc-800"
                                    >
                                        {formattedDate}
                                    </span>
                                </span>
                            </div>
                        </div>
                    </header>

                    <div
                        class="blog-content text-lg text-justify text-[1rem] md:text-[1.125rem]"
                    >
                        <slot />
                    </div>

                    <!-- <hr class="border-zinc-800 my-14" /> -->

                    <!-- <div
                        class="flex justify-between items-center text-sm text-zinc-500"
                    >
                        <p>Thanks for reading.</p>
                    </div> -->
                </article>

                <BlogFooter />
            </div>
        </div>
    </body>
</html>

<script>
    document.querySelectorAll(".markdown-image-wrapper img").forEach((img) => {
        const reveal = () => {
            const wrapper = img.closest(".markdown-image-wrapper");
            const placeholder = wrapper?.querySelector(".blur-placeholder");

            img.style.opacity = "1";
            if (placeholder) placeholder.style.opacity = "0";
        };

        // already cached (navigating back, fast load)
        img.complete ? reveal() : img.addEventListener("load", reveal);
    });
</script>

<style is:global>
    @import "../styles/global.css";

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }

    /* Blog post content styling */
    .blog-content p {
        margin-bottom: 2rem;
        line-height: 1.85;
        color: theme("colors.zinc.300");
    }

    .blog-content h2 {
        font-size: 1.5rem;
        font-weight: 600;
        color: theme("colors.zinc.100");
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.025em;
    }

    .blog-content h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: theme("colors.zinc.200");
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }

    .blog-content ul {
        margin-bottom: 2rem;
        list-style-type: disc;
        padding-left: 1.5rem;
        color: theme("colors.zinc.300");
    }

    .blog-content ul li {
        line-height: 1.75;
        margin-bottom: 0.75rem;
    }

    .blog-content ol {
        margin-bottom: 2rem;
        list-style-type: decimal;
        padding-left: 1.5rem;
        color: theme("colors.zinc.300");
    }

    .blog-content ol li {
        line-height: 1.75;
        margin-bottom: 0.75rem;
    }

    .blog-content strong {
        font-weight: 500;
        color: theme("colors.zinc.100");
    }

    .blog-content a {
        /* color: theme("colors.zinc.100"); */
        /* color: #7389f4; */
        color: #6688ff;
        text-decoration: underline;
        text-underline-offset: 3px;
        transition: color 0.2s;
    }

    .blog-content a:hover {
        color: #bdc1f9;
    }

    .blog-content blockquote {
        border-left: 3px solid theme("colors.zinc.700");
        padding-left: 1.25rem;
        margin: 2rem 0;
        color: theme("colors.zinc.400");
        font-style: italic;
    }

    .blog-content pre.astro-code {
        padding: 1rem;
        border-radius: 0.75rem;
        margin: 2rem 0;
        font-size: 0.9rem;
        border: 1px solid theme("colors.zinc.800");
    }

    .blog-content :not(pre) > code {
        color: #ffcc00;
        background-color: #1e1e1e;
        padding: 2px 6px;
        border-radius: 6px;
        font-size: 0.9em;
    }

    .blog-content img {
        max-width: 100%;
        height: auto;
        border-radius: 1rem;
    }

    /* Image wrapper styles */
    .markdown-image-wrapper {
        margin: 1.5rem auto;
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid theme("colors.zinc.800");
    }

    .markdown-image-wrapper img {
        border-radius: 1rem;
    }

    .blur-placeholder {
        border-radius: 1rem;
        filter: blur(8px);
        transform: scale(1.05);
    }

    div.markdown-image-bg-placeholder {
        border-radius: 0.75rem;
        margin: 4%;
    }
</style>
