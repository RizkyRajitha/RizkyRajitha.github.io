---
import "@fontsource/space-mono";

const origin = Astro.url.origin;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Rajitha's Blog</title>
        <meta name="description" content="Personal blog of Rajitha on devops, software engineering, coding, development, engineering, home automation, networking" />
        <meta name="og:type" content="website" />
        <meta name="og:image" content={`${origin}/ogimg/blog.png`} />

        <meta property="og:locale" content="en_US" />
        <meta name="og:site_name" content="Rajitha's Blog" />

        <meta
            name="twitter:site"
            content={`https://twitter.com/rizkyrajitha`}
        />
        <meta
            name="keywords"
            content="devops, software engineering, coding, development, engineering, home automation, networking"
        />

        <meta name="og:title" content="Personal blog of Rajitha" />
        <script
            async
            defer
            data-website-id="02687704-8c50-4293-87a1-adfc7daf88b7"
            src="https://umami-five.vercel.app/script.js"></script>
    </head>

    <body
        class="min-h-screen bg-[#18181B] text-zinc-300 font-sans selection:bg-zinc-700 selection:text-white overflow-x-hidden"
    >
        <div class="max-w-3xl mx-auto px-6 md:px-8">
            <slot />
        </div>
    </body>
</html>

<style is:global>
    @import "../styles/global.css";

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
